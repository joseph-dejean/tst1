# ============================================
# Dataplex Business User Interface - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Google Cloud Project ---
VITE_GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# --- Google OAuth 2.0 ---
# Create credentials at: https://console.cloud.google.com/auth/clients
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your-client-secret
VITE_GOOGLE_REDIRECT_URI=/auth/google/callback

# --- API Configuration ---
VITE_API_URL=/api
VITE_API_VERSION=v1

# --- GCP Location ---
# Must be a specific region (not multi-region like "eu")
GCP_LOCATION=europe-west1
GCP_REGION=europe-west1

# --- Admin ---
SUPER_ADMIN_EMAIL=your-admin@example.com
VITE_ADMIN_EMAIL=your-admin@example.com

# --- Email Notifications (Optional) ---
# SMTP_EMAIL=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# --- ServiceNow Integration (Optional) ---
# SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
# SERVICENOW_USERNAME=your-username
# SERVICENOW_PASSWORD=your-password
# SERVICENOW_TABLE_NAME=x_1945757_datapl_0_access_request

# --- Server ---
PORT=8080
